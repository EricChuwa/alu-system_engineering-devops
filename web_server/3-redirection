#!/usr/bin/env bash
# Installs and configures Nginx with a 301 redirect on /redirect_me

apt-get update -y
apt-get install -y nginx

# Create the custom index page
echo "Holberton School for the win!" > /var/www/html/index.html

# Use sed to replace the existing location / block with redirect config
sed -i '/listen 80 default_server;/a\\tlocation /redirect_me {\n\t\treturn 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;\n\t}' /etc/nginx/sites-available/default

# Restart nginx without systemctl
nginx -t && service nginx restart

