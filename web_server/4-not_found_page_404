#!/usr/bin/env bash
# Installs and configures Nginx with:
# - "Holberton School" index page
# - 301 redirect on /redirect_me
# - Custom 404 page containing "Ceci n'est pas une page"

apt-get update -y
apt-get install -y nginx

# Create the custom index page
echo "Holberton School for the win!" > /var/www/html/index.html

# Create the custom 404 page
echo "Ceci n'est pas une page" > /var/www/html/404.html

# Use sed to replace the default server block with our custom config
sed -i '/listen 80 default_server;/a\\tlocation /redirect_me {\n\t\treturn 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;\n\t}\n\n\terror_page 404 /404.html;\n\tlocation = /404.html {\n\t\tinternal;\n\t}' /etc/nginx/sites-available/default

# Restart nginx without systemctl
nginx -t && service nginx restart

