#!/usr/bin/env bash
# Install and configure HAproxy load balancer with roundrobin algorithm

apt-get update -y
apt-get install -y haproxy

# Remove any existing frontend/backend blocks to avoid duplicates
sed -i '/^frontend/,$ d' /etc/haproxy/haproxy.cfg

# Append frontend and backend config
cat >> /etc/haproxy/haproxy.cfg << 'EOF'

frontend http_front
    bind *:80
    mode http
    default_backend http_back

backend http_back
    balance roundrobin
    mode http
    option forwardfor
    option http-server-close
    server 7040-web-01 54.173.55.181:80 check
    server 7040-web-02 54.211.203.174:80 check
EOF

# Enable HAproxy init script management
sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/haproxy

# Validate and restart
haproxy -c -f /etc/haproxy/haproxy.cfg
service haproxy restart
